-- ── SP 1: Crear una nueva compra completa ───────────────────────
-- Recibe JSON con los detalles, inserta header + details,
-- actualiza stock de cada insumo y genera la factura.
-- Parámetros:
--   @supplierId      INT
--   @employeeId      INT
--   @paymentMethod   VARCHAR(30)
--   @invoiceNumber   VARCHAR(20)
--   @taxRate         DECIMAL(5,2)   -- ej: 18.00
--   @detailsJson     NVARCHAR(MAX)  -- array JSON: [{supplyId, quantity, unitPrice}]

IF OBJECT_ID('dbo.SP_CreatePurchase', 'P') IS NOT NULL DROP PROCEDURE dbo.SP_CreatePurchase;
GO
CREATE PROCEDURE dbo.SP_CreatePurchase
    @supplierId     INT,
    @employeeId     INT,
    @paymentMethod  VARCHAR(30)    = 'Efectivo',
    @invoiceNumber  VARCHAR(20)    = NULL,
    @taxRate        DECIMAL(5,2)   = 18.00,
    @detailsJson    NVARCHAR(MAX)
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;

        -- 1. Parsear JSON de detalles
        DECLARE @details TABLE (
            supplyId   INT,
            quantity   DECIMAL(10,3),
            unitPrice  DECIMAL(10,2),
            subtotal   DECIMAL(10,2)
        );

        INSERT INTO @details (supplyId, quantity, unitPrice, subtotal)
        SELECT
            JSON_VALUE(item.value, '$.supplyId'),
            JSON_VALUE(item.value, '$.quantity'),
            JSON_VALUE(item.value, '$.unitPrice'),
            CAST(JSON_VALUE(item.value, '$.quantity') AS DECIMAL(10,3))
            * CAST(JSON_VALUE(item.value, '$.unitPrice') AS DECIMAL(10,2))
        FROM OPENJSON(@detailsJson) AS item;

        -- Validar que haya al menos 1 ítem
        IF NOT EXISTS (SELECT 1 FROM @details)
            THROW 50001, 'Debe incluir al menos un insumo en la compra.', 1;

        -- Validar que todos los insumos existen
        IF EXISTS (
            SELECT 1 FROM @details d
            WHERE NOT EXISTS (SELECT 1 FROM Supply s WHERE s.supplyId = d.supplyId)
        )
            THROW 50002, 'Uno o más insumos no existen en el sistema.', 1;

        -- 2. Calcular totales
        DECLARE @subtotal   DECIMAL(10,2) = (SELECT SUM(subtotal) FROM @details);
        DECLARE @taxAmount  DECIMAL(10,2) = ROUND(@subtotal * @taxRate / 100, 2);
        DECLARE @total      DECIMAL(10,2) = @subtotal + @taxAmount;

        -- 3. Insertar cabecera
        DECLARE @headerId INT;
        INSERT INTO PurchaseHeader (purchaseDate, paymentMethod, status, subtotal, tax, total, invoiceNumber, supplier_supplierId, employee_employeeId)
        VALUES (GETDATE(), @paymentMethod, 'Recibido', @subtotal, @taxAmount, @total, @invoiceNumber, @supplierId, @employeeId);
        SET @headerId = SCOPE_IDENTITY();

        -- 4. Insertar detalles y actualizar stock
        INSERT INTO PurchaseDetail (quantity, unitPrice, subtotal, purchaseHeader_id, supply_supplyId)
        SELECT quantity, unitPrice, subtotal, @headerId, supplyId
        FROM @details;

        -- Actualizar stock (el TRIGGER trg_UpdateStockOnPurchase lo maneja también,
        -- pero lo dejamos aquí como respaldo directo)
        UPDATE s
        SET s.availableQuantity = s.availableQuantity + d.quantity
        FROM Supply s
        INNER JOIN @details d ON s.supplyId = d.supplyId;

        -- 5. Generar factura automáticamente
        DECLARE @supplierName    VARCHAR(100);
        DECLARE @supplierCompany VARCHAR(100);
        SELECT @supplierName = name, @supplierCompany = company
        FROM Supplier WHERE supplierId = @supplierId;

        INSERT INTO PurchaseInvoice (subtotal, taxRate, taxAmount, totalAmount, supplierName, supplierCompany, purchaseHeader_id)
        VALUES (@subtotal, @taxRate, @taxAmount, @total, @supplierName, @supplierCompany, @headerId);

        -- 6. Registrar en historial
        INSERT INTO PurchaseChangeLog (action, detail, purchaseHeader_id, employee_employeeId)
        VALUES (
            'Creó la compra',
            CONCAT('Se registró la compra por un total de $', @total, ' con ', (SELECT COUNT(*) FROM @details), ' insumo(s).'),
            @headerId,
            @employeeId
        );

        COMMIT TRANSACTION;

        -- Retornar el ID de la compra creada
        SELECT @headerId AS purchaseHeaderId;

    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END;
GO


-- ── SP 2: Editar una compra existente ───────────────────────────
IF OBJECT_ID('dbo.SP_UpdatePurchase', 'P') IS NOT NULL DROP PROCEDURE dbo.SP_UpdatePurchase;
GO
CREATE PROCEDURE dbo.SP_UpdatePurchase
    @purchaseHeaderId INT,
    @supplierId       INT,
    @employeeId       INT,
    @paymentMethod    VARCHAR(30),
    @status           VARCHAR(20),
    @invoiceNumber    VARCHAR(20) = NULL,
    @taxRate          DECIMAL(5,2) = 18.00,
    @detailsJson      NVARCHAR(MAX)
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;

        -- Verificar que la compra existe y no está anulada
        IF NOT EXISTS (SELECT 1 FROM PurchaseHeader WHERE purchaseHeaderId = @purchaseHeaderId)
            THROW 50003, 'La compra no existe.', 1;

        IF EXISTS (SELECT 1 FROM PurchaseHeader WHERE purchaseHeaderId = @purchaseHeaderId AND status = 'Anulado')
            THROW 50004, 'No se puede editar una compra anulada.', 1;

        -- Parsear nuevos detalles
        DECLARE @newDetails TABLE (
            supplyId   INT,
            quantity   DECIMAL(10,3),
            unitPrice  DECIMAL(10,2),
            subtotal   DECIMAL(10,2)
        );
        INSERT INTO @newDetails (supplyId, quantity, unitPrice, subtotal)
        SELECT
            JSON_VALUE(item.value, '$.supplyId'),
            JSON_VALUE(item.value, '$.quantity'),
            JSON_VALUE(item.value, '$.unitPrice'),
            CAST(JSON_VALUE(item.value, '$.quantity') AS DECIMAL(10,3))
            * CAST(JSON_VALUE(item.value, '$.unitPrice') AS DECIMAL(10,2))
        FROM OPENJSON(@detailsJson) AS item;

        -- Revertir stock anterior
        UPDATE s
        SET s.availableQuantity = s.availableQuantity - pd.quantity
        FROM Supply s
        INNER JOIN PurchaseDetail pd ON s.supplyId = pd.supply_supplyId
        WHERE pd.purchaseHeader_id = @purchaseHeaderId;

        -- Eliminar detalles anteriores
        DELETE FROM PurchaseDetail WHERE purchaseHeader_id = @purchaseHeaderId;

        -- Calcular nuevos totales
        DECLARE @subtotal   DECIMAL(10,2) = (SELECT SUM(subtotal) FROM @newDetails);
        DECLARE @taxAmount  DECIMAL(10,2) = ROUND(@subtotal * @taxRate / 100, 2);
        DECLARE @total      DECIMAL(10,2) = @subtotal + @taxAmount;

        -- Insertar nuevos detalles
        INSERT INTO PurchaseDetail (quantity, unitPrice, subtotal, purchaseHeader_id, supply_supplyId)
        SELECT quantity, unitPrice, subtotal, @purchaseHeaderId, supplyId
        FROM @newDetails;

        -- Aplicar nuevo stock
        UPDATE s
        SET s.availableQuantity = s.availableQuantity + d.quantity
        FROM Supply s
        INNER JOIN @newDetails d ON s.supplyId = d.supplyId;

        -- Actualizar cabecera
        UPDATE PurchaseHeader
        SET
            paymentMethod       = @paymentMethod,
            status              = @status,
            invoiceNumber       = @invoiceNumber,
            subtotal            = @subtotal,
            tax                 = @taxAmount,
            total               = @total,
            supplier_supplierId = @supplierId
        WHERE purchaseHeaderId = @purchaseHeaderId;

        -- Actualizar factura
        UPDATE PurchaseInvoice
        SET subtotal = @subtotal, taxAmount = @taxAmount, totalAmount = @total
        WHERE purchaseHeader_id = @purchaseHeaderId;

        -- Registrar cambio
        INSERT INTO PurchaseChangeLog (action, detail, purchaseHeader_id, employee_employeeId)
        VALUES (
            'Editó la compra',
            CONCAT('Se modificó la compra. Nuevo total: $', @total),
            @purchaseHeaderId,
            @employeeId
        );

        COMMIT TRANSACTION;
        SELECT @purchaseHeaderId AS purchaseHeaderId;

    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END;
GO


-- ── SP 3: Anular una compra ─────────────────────────────────────
IF OBJECT_ID('dbo.SP_CancelPurchase', 'P') IS NOT NULL DROP PROCEDURE dbo.SP_CancelPurchase;
GO
CREATE PROCEDURE dbo.SP_CancelPurchase
    @purchaseHeaderId INT,
    @employeeId       INT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;

        IF NOT EXISTS (SELECT 1 FROM PurchaseHeader WHERE purchaseHeaderId = @purchaseHeaderId)
            THROW 50005, 'La compra no existe.', 1;

        IF EXISTS (SELECT 1 FROM PurchaseHeader WHERE purchaseHeaderId = @purchaseHeaderId AND status = 'Anulado')
            THROW 50006, 'La compra ya está anulada.', 1;

        -- Revertir stock
        UPDATE s
        SET s.availableQuantity = s.availableQuantity - pd.quantity
        FROM Supply s
        INNER JOIN PurchaseDetail pd ON s.supplyId = pd.supply_supplyId
        WHERE pd.purchaseHeader_id = @purchaseHeaderId;

        -- Anular cabecera
        UPDATE PurchaseHeader SET status = 'Anulado' WHERE purchaseHeaderId = @purchaseHeaderId;

        -- Registrar
        INSERT INTO PurchaseChangeLog (action, detail, purchaseHeader_id, employee_employeeId)
        VALUES (
            'Anuló la compra',
            'La compra fue anulada. El stock fue revertido.',
            @purchaseHeaderId,
            @employeeId
        );

        COMMIT TRANSACTION;

    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END;
GO


-- ── SP 4: Disminuir stock manualmente con doble validación ──────
IF OBJECT_ID('dbo.SP_DecreaseStock', 'P') IS NOT NULL DROP PROCEDURE dbo.SP_DecreaseStock;
GO
CREATE PROCEDURE dbo.SP_DecreaseStock
    @supplyId   INT,
    @quantity   DECIMAL(10,3),
    @reason     VARCHAR(200) = 'Ajuste manual',
    @employeeId INT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;

        -- Verificar existencia
        IF NOT EXISTS (SELECT 1 FROM Supply WHERE supplyId = @supplyId)
            THROW 50007, 'El insumo no existe.', 1;

        DECLARE @current DECIMAL(10,3);
        SELECT @current = availableQuantity FROM Supply WHERE supplyId = @supplyId;

        -- Validar que no quede en negativo
        IF @current - @quantity < 0
            THROW 50008, 'Stock insuficiente para realizar el ajuste.', 1;

        IF @quantity <= 0
            THROW 50009, 'La cantidad a disminuir debe ser mayor a cero.', 1;

        -- Disminuir
        UPDATE Supply SET availableQuantity = availableQuantity - @quantity WHERE supplyId = @supplyId;

        -- Registrar ajuste
        INSERT INTO StockAdjustment (quantityDecreased, reason, supply_supplyId, employee_employeeId)
        VALUES (@quantity, @reason, @supplyId, @employeeId);

        COMMIT TRANSACTION;

    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END;
GO


