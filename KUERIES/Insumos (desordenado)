-- ── TRG 1: Validar stock no negativo antes de cualquier UPDATE ──
IF OBJECT_ID('dbo.trg_PreventNegativeStock', 'TR') IS NOT NULL DROP TRIGGER dbo.trg_PreventNegativeStock;
GO
CREATE TRIGGER dbo.trg_PreventNegativeStock
ON Supply
AFTER UPDATE
AS
BEGIN
    SET NOCOUNT ON;
    IF EXISTS (SELECT 1 FROM inserted WHERE availableQuantity < 0)
    BEGIN
        ROLLBACK TRANSACTION;
        THROW 50010, 'El stock no puede quedar en negativo.', 1;
    END
END;
GO


-- ── TRG 2: Auto-marcar estado "Stock Bajo" en Supply ────────────
--   Agrega columna stockAlert 
IF NOT EXISTS (
    SELECT 1 FROM sys.columns
    WHERE object_id = OBJECT_ID('Supply') AND name = 'stockAlert'
)
BEGIN
    ALTER TABLE Supply ADD stockAlert BIT NOT NULL DEFAULT 0;
END
GO

IF OBJECT_ID('dbo.trg_CheckStockAlert', 'TR') IS NOT NULL DROP TRIGGER dbo.trg_CheckStockAlert;
GO
CREATE TRIGGER dbo.trg_CheckStockAlert
ON Supply
AFTER UPDATE
AS
BEGIN
    SET NOCOUNT ON;
    UPDATE s
    SET s.stockAlert = CASE WHEN s.availableQuantity <= s.minimumQuantity THEN 1 ELSE 0 END
    FROM Supply s
    INNER JOIN inserted i ON s.supplyId = i.supplyId;
END;
GO


-- ── TRG 3: Log automático al insertar PurchaseDetail ────────────
--   Cuando se agrega un detalle nuevo a una compra en edición,
--   registra el cambio con el nombre del insumo.
IF OBJECT_ID('dbo.trg_LogPurchaseDetailInsert', 'TR') IS NOT NULL DROP TRIGGER dbo.trg_LogPurchaseDetailInsert;
GO
CREATE TRIGGER dbo.trg_LogPurchaseDetailInsert
ON PurchaseDetail
AFTER INSERT
AS
BEGIN
    SET NOCOUNT ON;
    -- Solo loguea si la compra ya tenía estado 'Recibido' (no es nueva)
    -- La inserción inicial la maneja el SP; este trigger cubre ediciones parciales futuras.
    INSERT INTO PurchaseChangeLog (action, detail, purchaseHeader_id, employee_employeeId)
    SELECT
        'Editó la compra',
        CONCAT('Se agregó el insumo "', su.name, '" (', i.quantity, ' ', su.unitOfMeasure, ').'),
        i.purchaseHeader_id,
        ph.employee_employeeId
    FROM inserted i
    INNER JOIN Supply          su ON su.supplyId         = i.supply_supplyId
    INNER JOIN PurchaseHeader  ph ON ph.purchaseHeaderId = i.purchaseHeader_id
    WHERE ph.status = 'Recibido'
      AND NOT EXISTS (
            -- Evitar duplicado si el SP ya insertó el log
            SELECT 1 FROM PurchaseChangeLog cl
            WHERE cl.purchaseHeader_id = i.purchaseHeader_id
              AND cl.action = 'Creó la compra'
              AND cl.logDate > DATEADD(SECOND, -5, GETDATE())
          );
END;
GO


-- ================================================================
-- PASO 4: VISTA útil para el inventario general
-- ================================================================
IF OBJECT_ID('dbo.vw_SupplyInventory', 'V') IS NOT NULL DROP VIEW dbo.vw_SupplyInventory;
GO
CREATE VIEW dbo.vw_SupplyInventory AS
SELECT
    s.supplyId,
    s.name,
    s.availableQuantity,
    s.minimumQuantity,
    s.unitOfMeasure,
    s.stockAlert,
    sc.supplyCategoryId,
    sc.name              AS categoryName,
    -- Última compra
    lp.lastPurchaseDate,
    lp.lastSupplierName,
    lp.lastUnitPrice
FROM Supply s
INNER JOIN SupplyCategory sc ON sc.supplyCategoryId = s.supplyCategory_supplyCategoryId
OUTER APPLY (
    SELECT TOP 1
        ph.purchaseDate  AS lastPurchaseDate,
        sup.name         AS lastSupplierName,
        pd.unitPrice     AS lastUnitPrice
    FROM PurchaseDetail  pd
    INNER JOIN PurchaseHeader ph  ON ph.purchaseHeaderId = pd.purchaseHeader_id
    INNER JOIN Supplier        sup ON sup.supplierId       = ph.supplier_supplierId
    WHERE pd.supply_supplyId = s.supplyId
      AND ph.status <> 'Anulado'
    ORDER BY ph.purchaseDate DESC
) lp;
GO





