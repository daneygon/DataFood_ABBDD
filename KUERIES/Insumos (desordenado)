CREATE PROCEDURE dbo.SP_UpdatePurchase
    @purchaseHeaderId INT,
    @supplierId       INT,
    @employeeId       INT,
    @paymentMethod    VARCHAR(30),
    @status           VARCHAR(20),
    @invoiceNumber    VARCHAR(30) = NULL,   -- ampliado de 20 a 30
    @taxRate          DECIMAL(5,2) = 18.00,
    @detailsJson      NVARCHAR(MAX)
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        BEGIN TRANSACTION;

        IF NOT EXISTS (SELECT 1 FROM PurchaseHeader WHERE purchaseHeaderId = @purchaseHeaderId)
            THROW 50003, 'La compra no existe.', 1;

        IF EXISTS (SELECT 1 FROM PurchaseHeader WHERE purchaseHeaderId = @purchaseHeaderId AND status = 'Anulado')
            THROW 50004, 'No se puede editar una compra anulada.', 1;

        DECLARE @newDetails TABLE (
            supplyId   INT,
            quantity   DECIMAL(10,3),
            unitPrice  DECIMAL(10,2),
            subtotal   DECIMAL(10,2)
        );
        INSERT INTO @newDetails (supplyId, quantity, unitPrice, subtotal)
        SELECT
            JSON_VALUE(item.value, '$.supplyId'),
            JSON_VALUE(item.value, '$.quantity'),
            JSON_VALUE(item.value, '$.unitPrice'),
            CAST(JSON_VALUE(item.value, '$.quantity') AS DECIMAL(10,3))
            * CAST(JSON_VALUE(item.value, '$.unitPrice') AS DECIMAL(10,2))
        FROM OPENJSON(@detailsJson) AS item;

        UPDATE s
        SET s.availableQuantity = s.availableQuantity - pd.quantity
        FROM Supply s
        INNER JOIN PurchaseDetail pd ON s.supplyId = pd.supply_supplyId
        WHERE pd.purchaseHeader_id = @purchaseHeaderId;

        DELETE FROM PurchaseDetail WHERE purchaseHeader_id = @purchaseHeaderId;

        DECLARE @subtotal   DECIMAL(10,2) = (SELECT SUM(subtotal) FROM @newDetails);
        DECLARE @taxAmount  DECIMAL(10,2) = ROUND(@subtotal * @taxRate / 100, 2);
        DECLARE @total      DECIMAL(10,2) = @subtotal + @taxAmount;

        INSERT INTO PurchaseDetail (quantity, unitPrice, subtotal, purchaseHeader_id, supply_supplyId)
        SELECT quantity, unitPrice, subtotal, @purchaseHeaderId, supplyId
        FROM @newDetails;

        UPDATE s
        SET s.availableQuantity = s.availableQuantity + d.quantity
        FROM Supply s
        INNER JOIN @newDetails d ON s.supplyId = d.supplyId;

        UPDATE PurchaseHeader
        SET
            paymentMethod       = @paymentMethod,
            status              = @status,
            invoiceNumber       = @invoiceNumber,
            subtotal            = @subtotal,
            tax                 = @taxAmount,
            total               = @total,
            supplier_supplierId = @supplierId
        WHERE purchaseHeaderId = @purchaseHeaderId;

        UPDATE PurchaseInvoice
        SET subtotal = @subtotal, taxAmount = @taxAmount, totalAmount = @total
        WHERE purchaseHeader_id = @purchaseHeaderId;

        INSERT INTO PurchaseChangeLog (action, detail, purchaseHeader_id, employee_employeeId)
        VALUES (
            'Editó la compra',
            CONCAT('Se modificó la compra. Nuevo total: $', @total),
            @purchaseHeaderId,
            @employeeId
        );

        COMMIT TRANSACTION;
        SELECT @purchaseHeaderId AS purchaseHeaderId;

    END TRY
    BEGIN CATCH
        IF @@TRANCOUNT > 0 ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END;
GO

