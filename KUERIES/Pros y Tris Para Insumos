-- ================================================================
-- STORED PROCEDURE: CREAR COMPRA
-- ================================================================
IF OBJECT_ID('dbo.SP_CreatePurchase', 'P') IS NOT NULL
    DROP PROCEDURE dbo.SP_CreatePurchase;
GO

CREATE PROCEDURE dbo.SP_CreatePurchase

    @supplierId     INT,
    @employeeId     INT,
    @paymentMethod  VARCHAR(30) = 'Efectivo',
    @invoiceNumber  VARCHAR(30) = NULL,
    @taxRate        DECIMAL(5,2) = 18.00,
    @detailsJson    NVARCHAR(MAX)

AS
BEGIN

    SET NOCOUNT ON;

    BEGIN TRY

        BEGIN TRANSACTION;

        DECLARE @details TABLE (
            supplyId  INT,
            quantity  DECIMAL(10,3),
            unitPrice DECIMAL(10,2),
            subtotal  DECIMAL(10,2)
        );

        INSERT INTO @details
        SELECT
            JSON_VALUE(value, '$.supplyId'),
            CAST(JSON_VALUE(value, '$.quantity') AS DECIMAL(10,3)),
            CAST(JSON_VALUE(value, '$.unitPrice') AS DECIMAL(10,2)),
            CAST(JSON_VALUE(value, '$.quantity') AS DECIMAL(10,3))
                * CAST(JSON_VALUE(value, '$.unitPrice') AS DECIMAL(10,2))
        FROM OPENJSON(@detailsJson);

        IF NOT EXISTS (SELECT 1 FROM @details)
        BEGIN
            THROW 50001, 'Debe incluir al menos un insumo.', 1;
        END

        DECLARE @subtotal DECIMAL(10,2);
        DECLARE @taxAmount DECIMAL(10,2);
        DECLARE @total DECIMAL(10,2);

        SELECT @subtotal = SUM(subtotal)
        FROM @details;

        SET @taxAmount = ROUND(@subtotal * @taxRate / 100, 2);
        SET @total = @subtotal + @taxAmount;

        DECLARE @headerId INT;

        INSERT INTO PurchaseHeader (
            purchaseDate,
            paymentMethod,
            status,
            subtotal,
            tax,
            total,
            invoiceNumber,
            supplier_supplierId,
            employee_employeeId
        )
        VALUES (
            GETDATE(),
            @paymentMethod,
            'Recibido',
            @subtotal,
            @taxAmount,
            @total,
            @invoiceNumber,
            @supplierId,
            @employeeId
        );

        SET @headerId = SCOPE_IDENTITY();

        INSERT INTO PurchaseDetail (
            quantity,
            unitPrice,
            subtotal,
            purchaseHeader_id,
            supply_supplyId
        )
        SELECT
            quantity,
            unitPrice,
            subtotal,
            @headerId,
            supplyId
        FROM @details;

        UPDATE s
        SET s.availableQuantity = s.availableQuantity + d.quantity
        FROM Supply s
        INNER JOIN @details d
            ON d.supplyId = s.supplyId;

        DECLARE @supplierName VARCHAR(100);
        DECLARE @supplierCompany VARCHAR(100);

        SELECT
            @supplierName = name,
            @supplierCompany = company
        FROM Supplier
        WHERE supplierId = @supplierId;

        INSERT INTO PurchaseInvoice (
            subtotal,
            taxRate,
            taxAmount,
            totalAmount,
            supplierName,
            supplierCompany,
            purchaseHeader_id
        )
        VALUES (
            @subtotal,
            @taxRate,
            @taxAmount,
            @total,
            @supplierName,
            @supplierCompany,
            @headerId
        );

        INSERT INTO PurchaseChangeLog (
            action,
            detail,
            purchaseHeader_id,
            employee_employeeId
        )
        VALUES (
            'Creó la compra',
            CONCAT(
                'Compra registrada. Total: $',
                @total
            ),
            @headerId,
            @employeeId
        );

        COMMIT TRANSACTION;

        SELECT @headerId AS purchaseHeaderId;

    END TRY
    BEGIN CATCH

        IF @@TRANCOUNT > 0
            ROLLBACK TRANSACTION;

        THROW;

    END CATCH
END
GO


-- ================================================================
-- STORED PROCEDURE: EDITAR COMPRA
-- ================================================================
IF OBJECT_ID('dbo.SP_UpdatePurchase', 'P') IS NOT NULL
    DROP PROCEDURE dbo.SP_UpdatePurchase;
GO

CREATE PROCEDURE dbo.SP_UpdatePurchase

    @purchaseHeaderId INT,
    @supplierId       INT,
    @employeeId       INT,
    @paymentMethod    VARCHAR(30),
    @status           VARCHAR(20),
    @invoiceNumber    VARCHAR(30) = NULL,
    @taxRate          DECIMAL(5,2) = 18.00,
    @detailsJson      NVARCHAR(MAX)

AS
BEGIN

    SET NOCOUNT ON;

    BEGIN TRY

        BEGIN TRANSACTION;

        IF NOT EXISTS (
            SELECT 1
            FROM PurchaseHeader
            WHERE purchaseHeaderId = @purchaseHeaderId
        )
        BEGIN
            THROW 50003, 'La compra no existe.', 1;
        END

        DECLARE @newDetails TABLE (
            supplyId  INT,
            quantity  DECIMAL(10,3),
            unitPrice DECIMAL(10,2),
            subtotal  DECIMAL(10,2)
        );

        INSERT INTO @newDetails
        SELECT
            JSON_VALUE(value, '$.supplyId'),
            CAST(JSON_VALUE(value, '$.quantity') AS DECIMAL(10,3)),
            CAST(JSON_VALUE(value, '$.unitPrice') AS DECIMAL(10,2)),
            CAST(JSON_VALUE(value, '$.quantity') AS DECIMAL(10,3))
                * CAST(JSON_VALUE(value, '$.unitPrice') AS DECIMAL(10,2))
        FROM OPENJSON(@detailsJson);

        IF NOT EXISTS (SELECT 1 FROM @newDetails)
        BEGIN
            THROW 50004, 'Debe incluir al menos un insumo.', 1;
        END

        -- DEVOLVER STOCK ANTERIOR
        UPDATE s
        SET s.availableQuantity = s.availableQuantity + pd.quantity
        FROM Supply s
        INNER JOIN PurchaseDetail pd
            ON pd.supply_supplyId = s.supplyId
        WHERE pd.purchaseHeader_id = @purchaseHeaderId;

        DELETE FROM PurchaseDetail
        WHERE purchaseHeader_id = @purchaseHeaderId;

        DECLARE @subtotal DECIMAL(10,2);
        DECLARE @taxAmount DECIMAL(10,2);
        DECLARE @total DECIMAL(10,2);

        SELECT @subtotal = SUM(subtotal)
        FROM @newDetails;

        SET @taxAmount = ROUND(@subtotal * @taxRate / 100, 2);
        SET @total = @subtotal + @taxAmount;

        INSERT INTO PurchaseDetail (
            quantity,
            unitPrice,
            subtotal,
            purchaseHeader_id,
            supply_supplyId
        )
        SELECT
            quantity,
            unitPrice,
            subtotal,
            @purchaseHeaderId,
            supplyId
        FROM @newDetails;

        -- DESCONTAR NUEVO STOCK
        UPDATE s
        SET s.availableQuantity = s.availableQuantity - d.quantity
        FROM Supply s
        INNER JOIN @newDetails d
            ON d.supplyId = s.supplyId;

        UPDATE PurchaseHeader
        SET
            supplier_supplierId = @supplierId,
            paymentMethod = @paymentMethod,
            status = @status,
            invoiceNumber = @invoiceNumber,
            subtotal = @subtotal,
            tax = @taxAmount,
            total = @total
        WHERE purchaseHeaderId = @purchaseHeaderId;

        UPDATE PurchaseInvoice
        SET
            subtotal = @subtotal,
            taxAmount = @taxAmount,
            totalAmount = @total
        WHERE purchaseHeader_id = @purchaseHeaderId;

        INSERT INTO PurchaseChangeLog (
            action,
            detail,
            purchaseHeader_id,
            employee_employeeId
        )
        VALUES (
            'Editó la compra',
            CONCAT(
                'Compra editada. Nuevo total: $',
                @total
            ),
            @purchaseHeaderId,
            @employeeId
        );

        COMMIT TRANSACTION;

        SELECT @purchaseHeaderId AS purchaseHeaderId;

    END TRY
    BEGIN CATCH

        IF @@TRANCOUNT > 0
            ROLLBACK TRANSACTION;

        THROW;

    END CATCH
END
GO


-- ================================================================
-- STORED PROCEDURE: ANULAR COMPRA
-- ================================================================
IF OBJECT_ID('dbo.SP_CancelPurchase', 'P') IS NOT NULL
    DROP PROCEDURE dbo.SP_CancelPurchase;
GO

CREATE PROCEDURE dbo.SP_CancelPurchase

    @purchaseHeaderId INT,
    @employeeId INT

AS
BEGIN

    SET NOCOUNT ON;

    BEGIN TRY

        BEGIN TRANSACTION;

        IF NOT EXISTS (
            SELECT 1
            FROM PurchaseHeader
            WHERE purchaseHeaderId = @purchaseHeaderId
        )
        BEGIN
            THROW 50005, 'La compra no existe.', 1;
        END

        UPDATE s
        SET s.availableQuantity = s.availableQuantity - pd.quantity
        FROM Supply s
        INNER JOIN PurchaseDetail pd
            ON pd.supply_supplyId = s.supplyId
        WHERE pd.purchaseHeader_id = @purchaseHeaderId;

        UPDATE PurchaseHeader
        SET status = 'Anulado'
        WHERE purchaseHeaderId = @purchaseHeaderId;

        INSERT INTO PurchaseChangeLog (
            action,
            detail,
            purchaseHeader_id,
            employee_employeeId
        )
        VALUES (
            'Anuló la compra',
            'Compra anulada.',
            @purchaseHeaderId,
            @employeeId
        );

        COMMIT TRANSACTION;

    END TRY
    BEGIN CATCH

        IF @@TRANCOUNT > 0
            ROLLBACK TRANSACTION;

        THROW;

    END CATCH
END
GO


-- ================================================================
-- STORED PROCEDURE: AJUSTE MANUAL DE STOCK
-- ================================================================
IF OBJECT_ID('dbo.SP_DecreaseStock', 'P') IS NOT NULL
    DROP PROCEDURE dbo.SP_DecreaseStock;
GO

CREATE PROCEDURE dbo.SP_DecreaseStock

    @supplyId INT,
    @quantity DECIMAL(10,3),
    @reason VARCHAR(200) = 'Ajuste manual',
    @employeeId INT

AS
BEGIN

    SET NOCOUNT ON;

    BEGIN TRY

        BEGIN TRANSACTION;

        DECLARE @current DECIMAL(10,3);

        SELECT @current = availableQuantity
        FROM Supply
        WHERE supplyId = @supplyId;

        IF @current - @quantity < 0
        BEGIN
            THROW 50008, 'Stock insuficiente.', 1;
        END

        UPDATE Supply
        SET availableQuantity = availableQuantity - @quantity
        WHERE supplyId = @supplyId;

        INSERT INTO StockAdjustment (
            quantityDecreased,
            reason,
            supply_supplyId,
            employee_employeeId
        )
        VALUES (
            @quantity,
            @reason,
            @supplyId,
            @employeeId
        );

        COMMIT TRANSACTION;

    END TRY
    BEGIN CATCH

        IF @@TRANCOUNT > 0
            ROLLBACK TRANSACTION;

        THROW;

    END CATCH
END
GO


-- ================================================================
