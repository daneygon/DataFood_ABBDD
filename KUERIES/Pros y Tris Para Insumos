-- Evitar stock negativo
IF OBJECT_ID('dbo.trg_PreventNegativeStock', 'TR') IS NOT NULL
    DROP TRIGGER dbo.trg_PreventNegativeStock;
GO

CREATE TRIGGER dbo.trg_PreventNegativeStock
ON Supply
AFTER UPDATE
AS
BEGIN

    SET NOCOUNT ON;

    IF EXISTS (
        SELECT 1
        FROM inserted
        WHERE availableQuantity < 0
    )
    BEGIN
        ROLLBACK TRANSACTION;
        THROW 50010, 'El stock no puede quedar negativo.', 1;
    END
END
GO


-- Alerta stock bajo
IF OBJECT_ID('dbo.trg_CheckStockAlert', 'TR') IS NOT NULL
    DROP TRIGGER dbo.trg_CheckStockAlert;
GO

CREATE TRIGGER dbo.trg_CheckStockAlert
ON Supply
AFTER UPDATE
AS
BEGIN

    SET NOCOUNT ON;

    UPDATE s
    SET stockAlert =
        CASE
            WHEN s.availableQuantity <= s.minimumQuantity THEN 1
            ELSE 0
        END
    FROM Supply s
    INNER JOIN inserted i
        ON s.supplyId = i.supplyId;

END
GO


-- ================================================================
-- VISTA INVENTARIO
-- ================================================================
IF OBJECT_ID('dbo.vw_SupplyInventory', 'V') IS NOT NULL
    DROP VIEW dbo.vw_SupplyInventory;
GO

CREATE VIEW dbo.vw_SupplyInventory AS

SELECT

    s.supplyId,
    s.name,

    s.availableQuantity,
    s.minimumQuantity,

    s.unitOfMeasure,
    s.stockAlert,

    sc.supplyCategoryId,
    sc.name AS categoryName,

    lp.lastPurchaseDate,
    lp.lastSupplierName,
    lp.lastUnitPrice

FROM Supply s

INNER JOIN SupplyCategory sc
    ON sc.supplyCategoryId = s.supplyCategory_supplyCategoryId

OUTER APPLY (
    SELECT TOP 1

        ph.purchaseDate AS lastPurchaseDate,
        sup.name AS lastSupplierName,
        pd.unitPrice AS lastUnitPrice

    FROM PurchaseDetail pd

    INNER JOIN PurchaseHeader ph
        ON ph.purchaseHeaderId = pd.purchaseHeader_id

    INNER JOIN Supplier sup
        ON sup.supplierId = ph.supplier_supplierId

    WHERE pd.supply_supplyId = s.supplyId
    AND ph.status <> 'Anulado'

    ORDER BY ph.purchaseDate DESC

) lp;
GO

